# =============================================================================
# 环境变量模板（复制为 .env.development / .env.production 后按需修改）
#
# Vite 加载规则：
#   pnpm dev     → development 模式 → .env + .env.development + .env.local
#   pnpm build   → production  模式 → .env + .env.production + .env.local
#   pnpm preview → production  模式 → 同上（预览的是 build 产物）
#
# 优先级（后者覆盖前者）：.env < .env.[mode] < .env.local
# 只有 VITE_ 前缀的变量会暴露到 import.meta.env（见 src/utils/http/index.js）
# =============================================================================

# -----------------------------------------------------------------------------
# 接口基础路径（Axios baseURL，必须与 vite.config.js proxy 前缀一致）
# -----------------------------------------------------------------------------
# 开发：/dev-api → vite proxy 拦截 → mock 或转发到 VITE_PROXY_TARGET
# 生产：/prod-api → 由 nginx 反代到后端（见下方 nginx 示例）
VITE_BASE_API=/dev-api

# 开发联调真实后端时填写（留空则走 mock）
# 示例：VITE_PROXY_TARGET=http://127.0.0.1:8080
# 请求 /dev-api/auth/login 会被转发为 http://127.0.0.1:8080/auth/login
# VITE_PROXY_TARGET=

# -----------------------------------------------------------------------------
# 应用部署基础路径（对应 vite.config.js 的 base，影响静态资源与路由）
# -----------------------------------------------------------------------------
# 部署在子路径时改为 /子路径/，例如 /h5/
VITE_BASE_URL=/

# -----------------------------------------------------------------------------
# 调试与构建
# -----------------------------------------------------------------------------
# 是否在页面注入 Eruda 调试面板（开发 true，生产务必 false）
VITE_ENABLE_ERUDA=true

# 生产构建是否通过 CDN 加载 Vue 等依赖
VITE_CDN_DEPS=false

# -----------------------------------------------------------------------------
# 上传
# -----------------------------------------------------------------------------
# 图片/文件上传接口完整路径或相对路径（留空则 ImageUpload/FileUpload 仅本地预览）
# 开发 mock 阶段可留空；生产需配置，例如 /prod-api/common/upload
VITE_UPLOAD_URL=

# =============================================================================
# 生产 nginx 反代示例（VITE_BASE_API=/prod-api 时）
# =============================================================================
# location /prod-api/ {
#   proxy_pass http://backend-server/api/;   # 去掉 /prod-api 前缀后转发
#   proxy_set_header Host $host;
#   proxy_set_header X-Real-IP $remote_addr;
# }
#
# 若后端本身带 /api 前缀，可按需调整 rewrite，例如：
#   proxy_pass http://backend-server/;     # 保留 /prod-api/... 原样转发
